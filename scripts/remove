#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICES
#=================================================
ynh_script_progression "Stopping Zammad services..."

for svc in zammad-websocket zammad-worker zammad-web zammad; do
    if systemctl list-units --full --all | grep -q "${svc}.service"; then
        systemctl stop "$svc" 2>/dev/null || true
        systemctl disable "$svc" --quiet 2>/dev/null || true
    fi
done

#=================================================
# REMOVE PACKAGE
#=================================================
ynh_script_progression "Removing Zammad and Elasticsearch packages..."

DEBIAN_FRONTEND=noninteractive apt-get purge -y zammad elasticsearch 2>&1 || true
apt-get autoremove -y 2>/dev/null || true

#=================================================
# REMOVE APT REPOSITORY
#=================================================
ynh_script_progression "Removing Zammad repository..."

rm -f /etc/apt/sources.list.d/zammad.list
rm -f /etc/apt/keyrings/pkgr-zammad.gpg
rm -f /etc/apt/sources.list.d/elasticsearch.list
rm -f /etc/apt/keyrings/elasticsearch.gpg
apt-get update -qq

#=================================================
# REMOVE NGINX CONFIG
#=================================================
ynh_script_progression "Removing NGINX configuration..."
ynh_config_remove_nginx

# Also clean up the disabled Zammad nginx config
rm -f /etc/nginx/conf.d/zammad.conf.disabled
rm -f /etc/nginx/conf.d/zammad.conf

#=================================================
# REMOVE FAIL2BAN & LOGROTATE
#=================================================
ynh_config_remove_fail2ban
ynh_config_remove_logrotate

#=================================================
# DROP POSTGRESQL DATABASE
#=================================================
ynh_script_progression "Removing Zammad PostgreSQL database..."

# Zammad's Debian package creates its own PostgreSQL user/database.
# dpkg purge does NOT drop them — we must do it manually, or the next
# install will find a stale database and the postinst will fail.
sudo -u postgres dropdb   zammad 2>/dev/null || true
sudo -u postgres dropuser zammad 2>/dev/null || true

#=================================================
# REMOVE REMAINING FILES
#=================================================
ynh_script_progression "Removing remaining files..."

# Zammad data and config (purge may not remove these if non-empty)
ynh_safe_rm "/opt/zammad"
ynh_safe_rm "/var/lib/zammad"
ynh_safe_rm "/etc/zammad"
ynh_safe_rm "/var/log/zammad"
# Elasticsearch leftover data
ynh_safe_rm "/var/lib/elasticsearch"

ynh_script_progression "Zammad has been removed."
