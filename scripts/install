#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# SYSTEM DEPENDENCIES & REPO
#=================================================
ynh_script_progression "Adding Zammad repository..."

# Install prerequisites for the repo
ynh_apt_install_dependencies curl apt-transport-https gnupg libimlib2

# Detect Debian version number (e.g. 12 for bookworm) — packager.io uses numbers, not codenames
debian_version=$(lsb_release -sr | cut -d. -f1)

# Add Zammad GPG key
mkdir -p /etc/apt/keyrings
curl -fsSL "https://dl.packager.io/srv/zammad/zammad/key" \
    | gpg --dearmor \
    | tee /etc/apt/keyrings/pkgr-zammad.gpg > /dev/null
chmod 644 /etc/apt/keyrings/pkgr-zammad.gpg

# Add Zammad apt repository
echo "deb [signed-by=/etc/apt/keyrings/pkgr-zammad.gpg] https://dl.packager.io/srv/deb/zammad/zammad/stable/debian ${debian_version} main" \
    > /etc/apt/sources.list.d/zammad.list

# Add Elasticsearch repository (Zammad package hard-depends on it)
curl -fsSL "https://artifacts.elastic.co/GPG-KEY-elasticsearch" \
    | gpg --dearmor \
    | tee /etc/apt/keyrings/elasticsearch.gpg > /dev/null
chmod 644 /etc/apt/keyrings/elasticsearch.gpg
echo "deb [signed-by=/etc/apt/keyrings/elasticsearch.gpg] https://artifacts.elastic.co/packages/8.x/apt stable main" \
    > /etc/apt/sources.list.d/elasticsearch.list

apt-get update -qq

#=================================================
# INSTALL ELASTICSEARCH FIRST
#=================================================
ynh_script_progression "Installing Elasticsearch..."

# Install Elasticsearch before Zammad so Zammad's package finds the dependency
# already satisfied and skips its own Elasticsearch setup steps.
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends elasticsearch 2>&1

# Start and enable Elasticsearch, then wait for it to be ready
systemctl enable elasticsearch --quiet
systemctl start elasticsearch

ynh_script_progression "Waiting for Elasticsearch to be ready..."
es_timeout=300
es_elapsed=0
until systemctl is-active --quiet elasticsearch; do
    sleep 5
    es_elapsed=$((es_elapsed + 5))
    if [ "$es_elapsed" -ge "$es_timeout" ]; then
        ynh_die "Elasticsearch did not become active within ${es_timeout}s. Check: journalctl -u elasticsearch -n 50"
    fi
done
# Give Elasticsearch a moment to finish binding its port after becoming active
sleep 10

#=================================================
# INSTALL ZAMMAD PACKAGE
#=================================================
ynh_script_progression "Installing Zammad (this may take several minutes)..."

# Pre-create a dummy nginx config so Zammad's postinst doesn't generate one
# that YunoHost would detect as a conflicting app on the domain.
mkdir -p /etc/nginx/conf.d
touch /etc/nginx/conf.d/zammad.conf

# Zammad's package installs PostgreSQL, Redis, and configures them automatically.
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends zammad 2>&1

#=================================================
# DISABLE ZAMMAD'S OWN NGINX CONFIG
#=================================================
ynh_script_progression "Configuring NGINX..."

# Remove whatever Zammad's postinst wrote — YunoHost manages NGINX instead.
rm -f /etc/nginx/conf.d/zammad.conf
rm -f /etc/nginx/sites-enabled/zammad.conf
rm -f /etc/nginx/sites-available/zammad.conf
# Also remove any domain-specific conf dirs Zammad may have created
rm -rf /etc/nginx/conf.d/zammad.*.d/

# Deploy YunoHost NGINX config
ynh_config_add_nginx

#=================================================
# WAIT FOR ZAMMAD TO BE READY
#=================================================
# The zammad package postinst already started zammad.service.
# zammad-web.service is a placeholder (sleep infinity) — the real web
# server runs under zammad.service. Do NOT restart — first start runs
# DB migrations. Just enable and wait for the HTTP port.

systemctl enable zammad --quiet 2>/dev/null || true

ynh_script_progression "Waiting for Zammad web server on port $port (first start runs DB migrations — allow up to 10 minutes)..."

timeout=600
elapsed=0
while ! curl -sf -o /dev/null "http://127.0.0.1:$port/"; do
    sleep 10
    elapsed=$((elapsed + 10))
    if [ $((elapsed % 60)) -eq 0 ]; then
        ynh_print_info "Still waiting for Zammad... ${elapsed}s elapsed. zammad.service: $(systemctl is-active zammad 2>/dev/null || echo unknown)"
        ynh_print_info "Recent log: $(journalctl -u zammad -n 3 --no-pager 2>/dev/null | tail -1)"
    fi
    if [ "$elapsed" -ge "$timeout" ]; then
        ynh_print_warn "Check: journalctl -u zammad -n 100 --no-pager"
        ynh_print_warn "Check: tail -50 /var/log/zammad/production.log"
        ynh_die "Zammad did not respond on port $port after ${timeout}s."
    fi
done

#=================================================
# INITIAL APPLICATION CONFIGURATION
#=================================================
ynh_script_progression "Configuring Zammad application settings..."

# Set the application URL so Zammad generates correct links
# Zammad stores this in the database — use the rails runner
zammad_rails() {
    sudo -u zammad bash -c "cd /opt/zammad && bundle exec rails runner \"$1\"" 2>/dev/null
}

domain_url="https://${domain}"
zammad_rails "Setting.set('http_type', 'https'); Setting.set('fqdn', '${domain}')"

# Set the interface language
zammad_rails "Setting.set('locale_default', '${language}')"

#=================================================
# CREATE ADMIN USER
#=================================================
ynh_script_progression "Creating admin user..."

admin_email=$(ynh_user_get_info --username="$admin" --key="mail")
admin_password=$(ynh_string_random --length=24)

# Store password in YunoHost settings so it can be retrieved later
ynh_app_setting_set --key=admin_password --value="$admin_password"

zammad_rails "
u = User.where(login: '${admin}').first_or_initialize
u.login      = '${admin}'
u.firstname  = User.find_by(email: '${admin_email}')&.firstname || '${admin}'
u.lastname   = ''
u.email      = '${admin_email}'
u.password   = '${admin_password}'
u.roles      = Role.where(name: ['Admin', 'Agent'])
u.active     = true
u.save!
"

#=================================================
# LDAP CONFIGURATION
#=================================================
ynh_script_progression "Configuring LDAP authentication..."

ldap_password=$(ynh_app_setting_get --key=ldap_password 2>/dev/null || echo "")
if [ -z "$ldap_password" ]; then
    ldap_password=$(ynh_string_random --length=24)
    ynh_app_setting_set --key=ldap_password --value="$ldap_password"
fi

# Create a dedicated LDAP bind user in YunoHost
# (YunoHost LDAP is at ldap://localhost, base dc=yunohost,dc=org)
ynh_script_progression "Configuring Zammad LDAP source..."

zammad_rails "
src = LdapSource.where(name: 'YunoHost').first_or_initialize
src.name       = 'YunoHost'
src.host       = 'localhost'
src.port       = 389
src.options    = {
  'dc'         => 'dc=yunohost,dc=org',
  'base'       => 'ou=users,dc=yunohost,dc=org',
  'bind_user'  => 'cn=admin,dc=yunohost,dc=org',
  'bind_pw'    => '$(yunohost tools adminpw --quiet 2>/dev/null || echo '')',
  'uid'        => 'uid',
  'firstname'  => 'givenName',
  'lastname'   => 'sn',
  'email'      => 'mail',
}
src.active     = true
src.save!
"

#=================================================
# FAIL2BAN
#=================================================
ynh_script_progression "Configuring Fail2ban..."
ynh_config_add_fail2ban --logpath="/var/log/zammad/production.log" \
    --failregex="Failed login for .* from <HOST>"

#=================================================
# LOGROTATE
#=================================================
ynh_config_add_logrotate "/var/log/zammad"

#=================================================
# FINISH
#=================================================
ynh_script_progression "Installation of Zammad complete!"
